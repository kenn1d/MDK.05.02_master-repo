<Page x:Class="praktika29.Views.Orders.MainOrders"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:praktika29.Views.Orders"
      xmlns:elements="clr-namespace:praktika29.Views.Orders"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MainOrders">

    <Page.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#ff2dd61b" />
            <Setter Property="BorderBrush" Value="#ff2dd61b" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Page.Resources>

    <Grid>

        <ListView ItemsSource="{Binding Orders}" HorizontalContentAlignment="Stretch" Margin="0,0,0,45">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <elements:Order DataContext="{Binding}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Label Content="Список заказов" FontSize="18" Margin="5,0,0,5" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="250" />
        <Button Style="{StaticResource Update}"
     Command="{Binding OnAddOrderCommand}"
     Content="Добавить" Height="25" Width="70" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,10,10" Grid.Column="1">
            <Button.Effect>
                <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3" />
            </Button.Effect>
        </Button>
    </Grid>
</Page>
