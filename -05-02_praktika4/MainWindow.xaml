<Window x:Class="praktika4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:praktika4"
        mc:Ignorable="d"
        Title="Студенты КГАПОУ Авиатехикума" VerticalAlignment="Top" Height="450" Width="800" MinHeight="450" MinWidth="800" FontFamily="Arial Narrow">
    <Grid>
        <Grid Height="50" Margin="0,0,0,350" Background="#FFA7A7A7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Height="30" VerticalAlignment="Top" Margin="10,10,0,0" HorizontalAlignment="Left" Width="30"
           Stretch="UniformToFill" Source="/praktika4;component/Images/upload.png"/>
            <TextBox x:Name="tb_info" Text="Фамилия Имя Отчество" VerticalContentAlignment="Center"
           Margin="9.4,10,10.2,10" Grid.Column="1" Foreground="Black" FontSize="14"/>
            <TextBox x:Name="tb_scholarship" Text="получает" VerticalContentAlignment="Center"
           Margin="9.8, 10" Grid.Column="2" Foreground="Black" FontSize="14"/>
            <TextBox x:Name="tb_course" Text="4" VerticalContentAlignment="Center" Margin="9,10,9.6,10"
           Grid.Column="3" Foreground="Black" FontSize="14"/>
            <Button Click="btn_upload" VerticalContentAlignment="Center" Grid.Column="4" Margin="9, 10" FontSize="14" Content="Добавить"/>
            <Button Click="btn_search" VerticalContentAlignment="Center" Grid.Column="5" Margin="9, 10" FontSize="14" Content="Поиск по ФИО"/>
        </Grid>
        
        <ScrollViewer  Height="360" ScrollChanged="ScrollViewer_ScrollChanged" Margin="0,74,0,0">
            <StackPanel Margin="10" x:Name="parent">
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
