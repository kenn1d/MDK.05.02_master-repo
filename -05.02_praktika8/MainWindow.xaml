<Window x:Class="praktika8.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:praktika8"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#FF424242" Margin="0, 0, 0, 50">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Image x:Name="enemyImage1"
                    Margin="10,10,10.2,185.4" Source="images/easy.jpg" Visibility="Visible"/>
                <Label
                    x:Name="playerSkills1"
                    Content="Основыные характеристики персонажа:"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    FontWeight="Bold"
                    Margin="10,0,0,160" Foreground="White"/>
                <Label
                    x:Name="playerHealth1"
                    Content="Жизненные показатели: 100"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,130" Foreground="White"/>
            </Grid>
            <Grid Grid.Column="1">
                <Image x:Name="enemyImage2"
                    Margin="10,10,10.2,185.4" Source="images/hard.jpg" Visibility="Visible"/>
                <Label
                    x:Name="playerSkills2"
                    Content="Основыные характеристики персонажа:"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    FontWeight="Bold"
                    Margin="10,0,0,160" Foreground="White"/>
                <Label
                    x:Name="playerHealth2"
                    Content="Жизненные показатели: 100"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,130" Foreground="White"/>
            </Grid>
        </Grid>
        <Button Click="SetDamage" Content="Нанести урон" Margin="0,335,0,-50" />
        </Grid>
</Window>
