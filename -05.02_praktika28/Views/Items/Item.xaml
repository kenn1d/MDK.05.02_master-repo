<UserControl x:Class="praktika28.Views.Items.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:praktika28.Views.Items"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             FontFamily="Bahnschrift Light Candensed">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#ff2dd61b"/>
            <Setter Property="BorderBrush" Value="#ff2dd61b"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="Delete">
            <Setter Property="Background" Value="#ffd62f1b"/>
            <Setter Property="BorderBrush" Value="#ffd62f1b"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10" Background="White">
        <Grid.Effect>
            <DropShadowEffect Opacity="0.1"/>
        </Grid.Effect>
        <Image Width="40" Height="40" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left" Source="/Images/task.png"/>
        <Grid Margin="60,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>
            <Grid Margin="10" Height="60" VerticalAlignment="Top" Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Наименование:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                <TextBox
                    Text="{Binding Name}"
                    IsEnabled="{Binding IsEnable}"
                    VerticalContentAlignment="Center"
                    Margin="10,25,10,0"
                    VerticalAlignment="Top"
                    Height="25"/>
            </Grid>
            <Grid Margin="10,80,10,0" Height="60" VerticalAlignment="Top"
                  Background="White">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Приоритет:" VerticalAlignment="Top"
                       Margin="10,0,10,0"/>
                <ComboBox
                    Text="{Binding Priority}"
                    IsEnabled="{Binding IsEnable}"
                    VerticalContentAlignment="Center"
                    Margin="10,25,10,0"
                    VerticalAlignment="Top"
                    Height="25">
                    <ComboBoxItem>Высокий</ComboBoxItem>
                    <ComboBoxItem>Средний</ComboBoxItem>
                    <ComboBoxItem>Низкий</ComboBoxItem>
                </ComboBox>
            </Grid>
            <Grid Margin="10,10,10,0" Height="60" VerticalAlignment="Top"
                  Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Срок выполнения:" VerticalAlignment="Top"
                       Margin="10,0,10,0"/>
                <TextBox
                    Text="{Binding DateExecute}"
                    IsEnabled="{Binding IsEnable}"
                    VerticalContentAlignment="Center"
                    Margin="10,25,10,0"
                    VerticalAlignment="Top"
                    Height="25"/>
            </Grid>
            <Grid Margin="10,80,10,0" Height="60" VerticalAlignment="Top"
                  Background="White" Grid.Column="1">
                <Grid.Effect>
                    <DropShadowEffect Opacity="0.1"/>
                </Grid.Effect>
                <Label Content="Комментарий:" VerticalAlignment="Top"
                       Margin="10,0,10,0"/>
                <TextBox
                    Text="{Binding Comment}"
                    IsEnabled="{Binding IsEnable}"
                    VerticalContentAlignment="Center"
                    Margin="10,25,10,0"
                    VerticalAlignment="Top"
                    Height="25"/>
            </Grid>
            <Button Style="{StaticResource Update}"
                    Command="{Binding OnEdit}"
                    Content="{Binding IsEnableText}"
                    Height="25"
                    Width="70"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,145,10,0"
                    Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>
            <Button Style="{StaticResource Update}"
                    IsEnabled="{Binding IsEnable}"
                    Command="{Binding OnDone}"
                    Content="{Binding IsDoneText}"
                    Height="25"
                    Width="70"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,145,85,10"
                    Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>
            <Button Style="{StaticResource Delete}"
                    Command="{Binding OnDelete}"
                    IsEnabled="{Binding IsEnable}"
                    Content="Удалить"
                    Height="25"
                    Width="70"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,145,160,0"
                    Grid.Column="1">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>   
        </Grid>
    </Grid>
</UserControl>
