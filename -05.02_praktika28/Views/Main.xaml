<Page x:Class="praktika28.Views.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:praktika28.Views"
      xmlns:elements="clr-namespace:praktika28.Views.Items"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main" FontFamily="Bahnschrift Light Condensed">

    <Page.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#ff2dd61b" />
            <Setter Property="BorderBrush" Value="#ff2dd61b" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Page.Resources>

    <Grid>
        <Label Content="Поиск по названию" Margin="10,7,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="18"/>
        <TextBox x:Name="nameSercher" Text="{Binding NameSearch, UpdateSourceTrigger=PropertyChanged}" Margin="150,10" VerticalAlignment="Top" HorizontalAlignment="Left" Height="25" Width="100"/>

        <Label Content="Сортировка по приоритету" Margin="275,7,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="18"/>
        <ComboBox Text="{Binding PrioritySort, UpdateSourceTrigger=PropertyChanged}" Margin="450,10,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Height="25" Width="100">
            <ComboBoxItem>Высокий</ComboBoxItem>
            <ComboBoxItem>Средний</ComboBoxItem>
            <ComboBoxItem>Низкий</ComboBoxItem>
        </ComboBox>

        <ListView ItemsSource="{Binding Tasks}" HorizontalContentAlignment="Stretch" Margin="0,50,0,45">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <elements:Item DataContext="{Binding}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Button Style="{StaticResource Update}"
                Command="{Binding OnAddTask}"
                Content="Добавить" Height="25" Width="70" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,10,10" Grid.Column="1">
            <Button.Effect>
                <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3" />
            </Button.Effect>
        </Button>
        <Button Content="В таблицу" Command="{Binding GetTable}" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Right" Height="25" Width="100" />
    </Grid>
</Page>
