<Window x:Class="praktika2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:praktika2"
        mc:Ignorable="d"
        Title="Игра-кликер" Height="450" Width="800" MinHeight="450" MinWidth="800">
    <Grid
        Background="#FF424242" >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Label
            x:Name="playerDied"
            Content="Вы погибли!"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Margin="0,173,0,0"
            Foreground="Red"
            FontSize="22"
            FontWeight="Bold"
            Visibility="Hidden"/>
        <Button
            x:Name="Revive"
            Click="btnRevive"
            Content="Возродиться"
            Margin="127,217,127,151"
            Visibility="Hidden"/>

        <Border
            x:Name="HeroBorder"
            BorderBrush="Black"
            BorderThickness="1"
            Margin="10"
            Background="#FFFDFDFD"
            Visibility="Visible" >

            <Grid>
                <Image x:Name="enemyImage1"
                    Margin="10,10,10.2,185.4" Source="/Hero 1.png" Visibility="Visible"/>
                <Label
                    x:Name="playerSkills"
                    Content="Основыные характеристики персонажа:"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    FontWeight="Bold"
                    Margin="10,0,0,160"
                    />
                <Label
                    x:Name="playerHealth"
                    Content="Жизненные показатели: 100"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,130"
                    />
                <Label
                    x:Name="playerArmor"
                    Content="Броня: 100"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,100"
                    />
                <Label
                    x:Name="playerLevel"
                    Content="Уровень: 1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,70"
                    />
                <Label
                    x:Name="playerGlasses"
                    Content="Опыт: 1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,40"
                    />
                <Label
                    x:Name="playerMoney"
                    Content="Монеты: 0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,10"
                    />
            </Grid>
        </Border>

        <Border
            x:Name="EnemyBorder"
            BorderBrush="Black"
            BorderThickness="1"
            Margin="10,10,10,10"
            Background="#FFFDFDFD"
            Grid.Column="1"
            MouseDown="AttackEnemy"
            Visibility="Visible">

            <Grid>
                <Image x:Name="emptyImage"
                        Margin="10,10,10.2,185.4" Source="/Hero 2.png"/>
                <Label
                    Content="Основыные характеристики персонажа:"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    FontWeight="Bold"
                    Margin="10,0,0,160"/>
                <Label
                    x:Name="emptyHealth"
                    Content="Жизненные показатели: 100"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,130"/>
                <Label
                    x:Name="emptyArmor"
                    Content="Броня: 100"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,100"/>
                <Label
                    x:Name="Damage"
                    Content=""
                    FontWeight="Bold"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,70" Foreground="Red"/>
                <Label
                    x:Name="CounterAttack"
                    Content=""
                    FontWeight="Bold"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="10,0,0,39" Foreground="Red"/>
            </Grid>
        </Border>
    </Grid>
</Window>
