<Page x:Class="Client.Pages.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Client.Pages"
      mc:Ignorable="d" 
      Title="Login">

    <Grid>
        <StackPanel Width="200" Margin="0,0,0,-4">
            <Label Content="Вход" Height="25" HorizontalContentAlignment="Center" Foreground="Red"/>
            <Label Content="Логин:" Height="25"/>
            <TextBox x:Name="tbLogin" Height="25"/>
            <Label Content="Пароль:" Height="25"/>
            <PasswordBox x:Name="tbPassword" Height="25"/>
            <Button Click="BthAuth" Content="Войти" Height="25" Width="200" Margin="0,10,0,0" HorizontalAlignment="Right"/>
            <Label Content="Нет аккаунта?" Height="25" HorizontalContentAlignment="Right" HorizontalAlignment="Right"/>
            <Button Click="toReg" Content="Регистрация" Height="25" Width="200" Margin="0,10,0,0" HorizontalAlignment="Right"/>
        </StackPanel>
    </Grid>
</Page>
