<Window x:Class="praktika27.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:praktika27"
        mc:Ignorable="d"
        Title="MainWindow" MinHeight="450" MinWidth="800" Height="450" Width="800"
        FontFamily="Centry Gothic" Icon="Images/shop.png">
    <Grid>
        <Frame x:Name="frame" NavigationUIVisibility="Hidden" Margin="5,55,5,5" Background="#fffafafa"/>
        <Grid Margin="0,0,0,379">
            <Grid.Effect>
                <DropShadowEffect Direction="270" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
            </Grid.Effect>
            <Label Content="Вещи для дома" HorizontalContentAlignment="Center" VerticalAlignment="Top" VerticalContentAlignment="Center" FontSize="15pt" Height="55"/>
            <Image Width="30" Height="30" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left" Source="Images/shop.png" MouseDown="OpenIndexItems" />
            <Image Width="30" Height="30" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Right" Source="Images/category.png" MouseDown="OpenIndexCategorys" />
        </Grid>
    </Grid>
</Window>
