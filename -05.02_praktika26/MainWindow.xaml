<Window x:Class="praktika26.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:praktika26"
        mc:Ignorable="d"
        Title="MainWindow" MinHeight="450" MinWidth="800" Height="450" Width="800">
    <Grid>
        <Button x:Name="BthClubs" Click="Clubs" Height="25" Content="Клубы" VerticalAlignment="Top" Margin="10,10,0,0" HorizontalAlignment="Left"
                Width="100" Background="#ff46fd00" BorderBrush="#ff46fd00" Foreground="White" IsEnabled="False"/>
        <Button x:Name="BthUsers" Click="Users" Height="25" Content="Пользователи" VerticalAlignment="Top" Margin="115,10,0,0" HorizontalAlignment="Left"
                Width="100" Background="#ff46fd00" BorderBrush="#ff46fd00" Foreground="White" IsEnabled="False"/>
        <Frame x:Name="frame" NavigationUIVisibility="Hidden" Margin="0,40,0,0"/>
    </Grid>
</Window>
