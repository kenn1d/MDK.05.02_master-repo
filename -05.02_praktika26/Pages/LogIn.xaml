<Page x:Class="praktika26.Pages.LogIn"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:praktika26.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LogIn">

    <Grid>
        <Grid Margin="20" Background="#fff0f0f0">
            <Label
                Content="Добро пожаловать!"
                FontSize="24" HorizontalAlignment="Center" Margin="70" Height="40" VerticalAlignment="Top" Foreground="Black"/>
            <TextBox 
                x:Name="Login"
                HorizontalAlignment="Center"
                Text="admin"
                Width="150" Margin="0,192,0,0" Height="26" VerticalAlignment="Top" BorderBrush="#FF004AFF"/>
            <TextBox 
                x:Name="Password"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Text="12345678"
                Height="26"
                Width="150"
                Margin="0,222,0,0" BorderBrush="#FF004AFF"/>
            <Button 
                x:Name="BthLogin"
                Click="login"
                Content="Войти"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,253,0,0"
                Width="150"
                Height="25" Background="#FF004AFF" BorderBrush="White" Foreground="White" />
        </Grid>
    </Grid>
</Page>
