<Page x:Class="praktika26.Pages.Clubs.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:praktika26.Pages.Clubs"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid>
        <Grid Margin="20" Background="#fff0f0f0">
            <ScrollViewer Margin="0,0,0,50">
                <StackPanel x:Name="Parent"/>
            </ScrollViewer>
            <Button 
                x:Name="BthName"
                Click="SortName"
                Height="25"
                Content="По имени"
                VerticalAlignment="Bottom"
                Margin="10"
                HorizontalAlignment="Left"
                Width="100"
                Background="#FF004AFF"
                BorderBrush="#FF004AFF"
                Foreground="White"/>
            <Button 
                x:Name="BthAddress"
                Click="SortAddress"
                Height="25"
                Content="По адресу"
                VerticalAlignment="Bottom"
                Margin="120,0,0,10"
                HorizontalAlignment="Left"
                Width="100"
                Background="#FF004AFF"
                BorderBrush="#FF004AFF"
                Foreground="White"/>
            <Button 
                x:Name="BthTime"
                Click="SortTime"
                Height="25"
                Content="По времени"
                VerticalAlignment="Bottom"
                Margin="230,0,0,10"
                HorizontalAlignment="Left"
                Width="100"
                Background="#FF004AFF"
                BorderBrush="#FF004AFF"
                Foreground="White"/>
            <TextBox
                x:Name="SearchParam"
                Height="25"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Left"
                Width="200"
                Margin="340,0,0,10"
                Background="White"
                BorderBrush="#FF004AFF"/>
            <Button 
                x:Name="BthAdd"
                Click="AddClub"
                Height="25"
                Content="Добавить"
                VerticalAlignment="Bottom"
                Margin="10"
                HorizontalAlignment="Right"
                Width="100"
                Background="#ff46fd00"
                BorderBrush="#ff46fd00"
                Foreground="White"/>
            
        </Grid>
    </Grid>
</Page>
