<Page x:Class="praktika26.Pages.Users.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:praktika26.Pages.Users"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid Margin="10" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100px"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Image Width="80" Height="80" VerticalAlignment="Top" Margin="10" Source="/Images/person.png"/>
        <Button x:Name="BthAdd" Click="AddUser" Height="25" Content="Добавить" VerticalAlignment="Top" Margin="10,95,10,0"
        Background="#ff46fd00" BorderBrush="#ff46fd00" Foreground="White"/>
        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Label Content="Дата аренды:" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,0,0"/>
            <DatePicker x:Name="RentStart" VerticalAlignment="Top" Margin="10,36,10,0" Height="25"
             VerticalContentAlignment="Center"/>

            <Label Content="Время аренды:" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,66,0,0"/>
            <TextBox x:Name="RentTime" Text="Время аренды" VerticalAlignment="Top" Margin="10,92,10,0" Height="25"
             VerticalContentAlignment="Center"/>

            <Label Content="Продолжительность:" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,10,0,0" Grid.Column="1"/>
            <TextBox x:Name="Duration" Text="Продолжительность" VerticalAlignment="Top" Margin="10,36,10,0" Height="25"
             VerticalContentAlignment="Center" Grid.Column="1"/>

            <Label Content="Клуб:" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,66,0,0" Grid.Column="1"/>
            <ComboBox x:Name="Clubs" VerticalAlignment="Top" Margin="10,92,10,0" Height="25"
             VerticalContentAlignment="Center" Grid.Column="1"/>

            <Label Content="ФИО:" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,120,0,0" Grid.ColumnSpan="2"/>
            <TextBox x:Name="FIO" Text="Кибанов Макар Евгеньевич" VerticalAlignment="Top" Margin="10,145,10,10" Height="25"
             VerticalContentAlignment="Center" Grid.ColumnSpan="2"/>
        </Grid>
    </Grid>
</Page>
