<Page x:Class="praktika26.Pages.Users.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:praktika26.Pages.Users"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid>
        <Grid Margin="20" Background="#fff0f0f0">
            <ScrollViewer Margin="0,0,0,80">
                <StackPanel x:Name="Parent"/>
            </ScrollViewer>
            <Button 
                x:Name="BthFIO"
                Click="SortFIO"
                Height="25"
                Content="По ФИО"
                VerticalAlignment="Bottom"
                Margin="10,0,0,40"
                HorizontalAlignment="Left"
                Width="100"
                Background="#FF004AFF"
                BorderBrush="#FF004AFF"
                Foreground="White"/>
            <Button 
                x:Name="BthRentStart"
                Click="SortRentStart"
                Height="25"
                Content="По брони"
                VerticalAlignment="Bottom"
                Margin="120,0,0,40"
                HorizontalAlignment="Left"
                Width="100"
                Background="#FF004AFF"
                BorderBrush="#FF004AFF"
                Foreground="White"/>
            <Button 
                x:Name="BthTime"
                Click="SortTime"
                Height="25"
                Content="По длительности"
                VerticalAlignment="Bottom"
                Margin="230,0,0,40"
                HorizontalAlignment="Left"
                Width="100"
                Background="#FF004AFF"
                BorderBrush="#FF004AFF"
                Foreground="White"/>
            <TextBox
                x:Name="SearchParam"
                Height="25"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Left"
                Width="540"
                Margin="10,0,0,10"
                Background="White"
                BorderBrush="#FF004AFF"/>
            <ComboBox
                x:Name="SearchClub"
                SelectionChanged="SelectClub"
                Height="25"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Left"
                Width="210"
                Margin="340,0,0,40"
                Background="White"
                BorderBrush="#FF004AFF"/>

            <Button 
                x:Name="BthAdd"
                Click="AddUser"
                Height="25"
                Content="Добавить"
                VerticalAlignment="Bottom"
                Margin="10"
                HorizontalAlignment="Right"
                Width="100"
                Background="#ff46fd00"
                BorderBrush="#ff46fd00"
                Foreground="White"/>

        </Grid>
    </Grid>
</Page>
